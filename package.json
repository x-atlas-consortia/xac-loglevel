{
  "name": "xac-loglevel",
  "version": "1.0.0",
  "description": "Minimal lightweight simple logging for JavaScript (browsers, node.js or elsewhere). ",
  "homepage": "https://github.com/x-atlas-consortia/xac-loglevel",
  "repository": {
    "type": "git",
    "url": "git@github.com:x-atlas-consortia/xac-loglevel.git"
  },
  "bugs": {
    "url": "https://github.com/x-atlas-consortia/xac-loglevel/issues"
  },
  "license": "MIT",
  "keywords": [
    "log",
    "logger",
    "logging",
    "browser"
  ],
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./index.d.ts",
  "files": [
    "dist",
    "index.d.ts",
    "README.md"
  ],
  "scripts": {
    "dev": "next dev",
    "dist": "rm -rf dist && cp src/lib/config.example.js src/lib/config.js &&  NODE_ENV=production node ./node_modules/xac-esbuild/index.js -s=src/lib/ -o=dist/ -banner=package.json -log=1  -t='**/*.{js,jsx,eot,css,svg,woff,woff2,ttf,otf}'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "devDependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "xac-esbuild": "github:x-atlas-consortia/xac-esbuild#1.0.0"
  }
}
